{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triangles.co.kr/cluster-installer/inventory.schema.json",
  "title": "Cluster Installer Inventory",
  "type": "object",
  "required": ["cluster", "network", "target", "nodes", "ceph", "addons", "content"],
  "additionalProperties": false,
  "properties": {
    "cluster": {
      "type": "object",
      "required": ["name", "domain", "kubernetes"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}[a-z0-9]$" },
        "domain": { "type": "string", "format": "hostname" },
        "timezone": { "type": "string", "default": "Asia/Seoul" },
        "kubernetes": {
          "type": "object",
          "required": ["distro", "version", "cni"],
          "additionalProperties": false,
          "properties": {
            "distro": { "enum": ["rke2", "k3s"] },
            "version": { "type": "string" },
            "cni": { "enum": ["cilium", "canal", "calico"] }
          }
        }
      }
    },
    "network": {
      "type": "object",
      "required": ["pod_cidr", "service_cidr", "vip", "lb_pool"],
      "additionalProperties": false,
      "properties": {
        "pod_cidr": { "type": "string" },
        "service_cidr": { "type": "string" },
        "vip": { "type": "string", "format": "ipv4" },
        "lb_pool": { "type": "string", "pattern": "^[0-9.]+-[0-9.]+$" },
        "ingress_lb_ip": { "type": "string", "format": "ipv4" },
        "gateway": { "type": "string", "format": "ipv4" },
        "nameservers": { "type": "array", "items": { "type": "string", "format": "ipv4" } },
        "prefix_len": { "type": "integer", "minimum": 8, "maximum": 30, "default": 24 },
        "cluster_prefix_len": { "type": "integer", "minimum": 8, "maximum": 30, "default": 24 }
      }
    },
    "target": {
      "type": "object",
      "required": ["type", "endpoint"],
      "additionalProperties": true,
      "properties": {
        "type": { "enum": ["libvirt", "proxmox", "esxi"] },
        "endpoint": { "type": "string", "description": "libvirt URI / Proxmox base URL / ESXi host URL (https://192.168.1.210/)" },
        "username": { "type": "string", "default": "root" },
        "ssh_key": { "type": "string", "description": "SSH private key path (libvirt always; ESXi optional alternative to password)" },
        "api_token": { "type": "string", "description": "Proxmox PVE API token (user@pam!tokenid=secret)" },
        "password": { "type": "string", "description": "ESXi root password (used for both vSphere API and SSH; never persisted in plaintext outside %LOCALAPPDATA%)" },
        "tls_insecure": { "type": "boolean", "default": false, "description": "ESXi defaults to self-signed cert; commonly true for lab clusters" },
        "datastore": { "type": "string", "description": "ESXi datastore for VM disks + seed ISOs (e.g. SSD-RAID0-4Ti-02)" },
        "iso_datastore": { "type": "string", "description": "ESXi datastore for ISO uploads (often same as datastore)" },
        "network": { "type": "string", "description": "ESXi port group name (e.g. 'VM Network')" },
        "advertise_ip": { "type": "string", "description": "Override for the host IP advertised to target VMs (auto-detected if blank)" }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["hostname", "ip", "roles", "os"],
        "additionalProperties": false,
        "properties": {
          "hostname": { "type": "string" },
          "ip": { "type": "string", "format": "ipv4" },
          "cluster_ip": { "type": "string", "format": "ipv4", "description": "Optional Ceph cluster network IP (C-Net) for OSD nodes" },
          "primary_mac": { "type": "string", "pattern": "^[0-9a-fA-F]{2}(:[0-9a-fA-F]{2}){5}$", "description": "Discovered after VM creation; bound in NM connection to survive multi-NIC additions" },
          "network_interface": { "type": "string", "description": "Primary NIC name (default: ens192 for ESXi vmxnet3, eth0 for libvirt virtio)" },
          "roles": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["control-plane", "etcd", "worker", "ceph-mon", "ceph-mgr", "ceph-osd", "ceph-mds", "ceph-rgw"] }
          },
          "os": { "enum": ["microos", "leap", "tumbleweed"] },
          "cpu": { "type": "integer", "minimum": 1, "default": 2 },
          "memory_gb": { "type": "integer", "minimum": 1, "default": 4 },
          "disk_gb": { "type": "integer", "minimum": 10, "default": 40 },
          "data_devices": {
            "type": "array",
            "items": { "type": "string", "pattern": "^/dev/" },
            "description": "OSD-only. BlueStore data devices (typically HDDs in a hybrid cluster). Required when roles includes ceph-osd."
          },
          "db_devices": {
            "type": "array",
            "items": { "type": "string", "pattern": "^/dev/" },
            "description": "OSD-only. Optional BlueStore DB devices (rocksdb). Recommended for HDD-backed OSDs — typically a faster SSD/NVMe."
          },
          "wal_devices": {
            "type": "array",
            "items": { "type": "string", "pattern": "^/dev/" },
            "description": "OSD-only. Optional separate WAL location. Rare; usually shares db_devices."
          },
          "osds_per_device": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16,
            "default": 1,
            "description": "OSD-only. OSD daemons per data device. >1 for very high-IOPS NVMe."
          },
          "osd_encrypted": {
            "type": "boolean",
            "default": false,
            "description": "OSD-only. Enable dm-crypt encryption-at-rest."
          },
          "device_class": {
            "enum": ["auto", "hdd", "ssd", "nvme"],
            "default": "auto",
            "description": "OSD-only. CRUSH device class — used for tier-aware pool placement rules."
          },
          "storage_devices": {
            "type": "array",
            "items": { "type": "string", "pattern": "^/dev/" },
            "description": "Deprecated: backward-compat alias for data_devices."
          },
          "datastore": {
            "type": "string",
            "description": "Per-node override of target.datastore. Used to distribute VMs across physical arrays for fault tolerance (Ceph mon quorum, etc.). Blank = inherit cluster-level value."
          },
          "disk_provisioning": {
            "enum": ["thin", "thick", "thick-eager"],
            "default": "thin",
            "description": "Virtual disk allocation strategy. thin=sparse, thick=preallocated lazy-zero, thick-eager=preallocated + zeroed at create (recommended for Ceph OSD data disks; ESXi-only — falls back to thick on libvirt/Proxmox)."
          },
          "ssh_authorized_keys": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ceph": {
      "type": "object",
      "required": ["mode", "public_network", "pools"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["external", "rook"] },
        "public_network": { "type": "string" },
        "cluster_network": { "type": "string" },
        "pools": {
          "type": "array",
          "items": { "enum": ["rbd", "cephfs", "rgw"] }
        },
        "replication": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "description": "Default replica count for the RBD/CephFS pools the wizard creates."
        },
        "failure_domain": {
          "enum": ["host", "rack", "chassis", "osd"],
          "default": "host",
          "description": "CRUSH bucket Ceph spreads replicas across. 'host' is standard; 'rack'/'chassis' need pre-configured CRUSH topology."
        },
        "default_osds_per_device": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "default_encrypted": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "addons": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ingress": { "enum": ["ingress-nginx", "traefik", "none"], "default": "ingress-nginx" },
        "cert_manager": { "type": "boolean", "default": true },
        "monitoring": { "enum": ["kube-prometheus-stack", "none"], "default": "kube-prometheus-stack" },
        "gitops": { "enum": ["argocd", "flux", "none"], "default": "none" }
      }
    },
    "content": {
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string", "description": "git tag or commit of the content repo" },
        "repo": { "type": "string", "format": "uri", "default": "https://github.com/cmars-devops/cluster-installer-content.git" }
      }
    }
  }
}

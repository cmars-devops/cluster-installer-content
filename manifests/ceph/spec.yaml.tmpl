---
# cephadm service spec — rendered per cluster from inventory.
# Reference: P:\K3s@IDC\config\ceph-spec.yaml (production-validated).
# Apply: ssh root@<bootstrap> "ceph orch apply -i /root/ceph-spec.yaml"
#
# Order matters in Ceph day-1:
#   1. host registration (this file's first N docs)
#   2. mon/mgr/mds placement by label
#   3. OSD spec(s) — emitted PER UNIQUE OSD shape so that nodes with
#      different data/db/wal layouts get their own service_id and
#      cephadm doesn't try to reconcile heterogeneous specs into one.
#   4. RGW (only after OSDs are up+in — see install playbook)

{{- range .Nodes }}
service_type: host
hostname: {{ .Hostname }}
addr: {{ .IP }}
labels:
{{- range .CephLabels }}
  - {{ . }}
{{- end }}
---
{{- end }}

# ── MON: 3대 quorum ─────────────────────────────────────────
service_type: mon
placement:
  label: mon
  count: {{ .Counts.Mon }}
---
# ── MGR: active + standby ──────────────────────────────────
service_type: mgr
placement:
  label: mgr
  count: {{ .Counts.Mgr }}
{{- if .Counts.Mds }}
---
# ── MDS: CephFS ────────────────────────────────────────────
service_type: mds
service_id: cephfs
placement:
  label: mds
  count: {{ .Counts.Mds }}
{{- end }}

{{- /*  OSD specs — group OSD nodes by their (data, db, wal, encrypted,
        osds_per_device, device_class) signature. Each unique signature
        becomes its own cephadm service_id. */ -}}
{{- range $i, $osd := .OSD.SpecGroups }}
---
service_type: osd
service_id: osds-{{ add $i 1 }}{{ if $osd.DeviceClass }}-{{ $osd.DeviceClass }}{{ end }}
placement:
  hosts:
{{- range $osd.Hosts }}
    - {{ . }}
{{- end }}
spec:
  data_devices:
    paths:
{{- range $osd.DataDevices }}
      - {{ . }}
{{- end }}
{{- if $osd.DBDevices }}
  db_devices:
    paths:
{{- range $osd.DBDevices }}
      - {{ . }}
{{- end }}
{{- end }}
{{- if $osd.WALDevices }}
  wal_devices:
    paths:
{{- range $osd.WALDevices }}
      - {{ . }}
{{- end }}
{{- end }}
  osds_per_device: {{ $osd.OSDsPerDevice }}
  encrypted: {{ $osd.Encrypted }}
{{- if $osd.DeviceClass }}
  crush_device_class: {{ $osd.DeviceClass }}
{{- end }}
{{- end }}

{{- if .Counts.Rgw }}
---
# ── RGW: S3 endpoint (HA) ──────────────────────────────────
service_type: rgw
service_id: {{ .RGW.Realm }}.{{ .RGW.Zone }}
placement:
  label: rgw
  count: {{ .Counts.Rgw }}
spec:
  rgw_realm: {{ .RGW.Realm }}
  rgw_zonegroup: {{ .RGW.Zonegroup }}
  rgw_zone: {{ .RGW.Zone }}
  rgw_frontend_type: beast
  rgw_frontend_port: 7480
{{- end }}
---
# ── crash + node-exporter on every host ────────────────────
service_type: crash
placement:
  host_pattern: "*"
---
service_type: node-exporter
placement:
  host_pattern: "*"
